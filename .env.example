# Required API Keys
# Copy this to .env and fill in your keys

# Groq API key (required) — get one at https://console.groq.com/keys
GROQ_API_KEY=

# Geoapify API key (required for accommodation + activity search)
# Free tier, no credit card — get one at https://myprojects.geoapify.com/
GEOAPIFY_API_KEY=

# Tavily API key (optional fallback if Geoapify data is thin for a city)
# Get one at https://app.tavily.com/home
TAVILY_API_KEY=
